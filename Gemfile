source "https://rubygems.org"

gem "jekyll"
gem "ffi", "1.15.5" # macOS 기본 Ruby(2.6) 호환성을 위해 버전 고정
gem "jekyll-sass-converter", "~> 2.2" # 사스 컨버터의 호환성 버그 우회

# This is the default theme for new Jekyll sites.
gem "minima", "~> 2.5"

# If you want to use GitHub Pages, remove the "gem "jekyll"" above and uncomment the line below. 
# gem "github-pages", group: :jekyll_plugins

# If you have any plugins, put them here!
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.12"
end

# To run locally on older Ruby versions which still ship with macOS
gem "webrick", "~> 1.7"
